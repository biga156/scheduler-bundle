{% extends base_template|default('@CaeligoScheduler/base.html.twig') %}

{% block title %}Edit — {{ command }}{% endblock %}

{% block scheduler_content %}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('caeligo_scheduler_index') }}">Tasks</a></li>
        <li class="breadcrumb-item active">{{ command }}</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Edit Task: <code>{{ command }}</code></h2>
    <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#edit-help" aria-expanded="false">
        <i class="fa fa-circle-question"></i> Help
    </button>
</div>

{% if command_info %}
    <p class="text-muted">{{ command_info.description }}</p>
{% endif %}

<div class="collapse mb-4" id="edit-help">
    <div class="card">
        <div class="card-body">
            <h6 class="card-title"><i class="fa fa-circle-info"></i> Editing a task</h6>
            <dl class="row mb-0">
                <dt class="col-sm-3">Schedule Type</dt>
                <dd class="col-sm-9">Choose between a <strong>Cron Expression</strong> (e.g. <code>0 * * * *</code> for every hour) or a <strong>Simple Interval</strong> (e.g. every 30 minutes). Only one can be active at a time.</dd>
                <dt class="col-sm-3">Cron Expression</dt>
                <dd class="col-sm-9">Standard 5-field cron format: <code>minute hour day month weekday</code>. Use <code>*</code> for "every", <code>*/N</code> for "every N", and comma-separated values for specific times.</dd>
                <dt class="col-sm-3">Arguments</dt>
                <dd class="col-sm-9">Extra arguments or options passed to the console command at execution, e.g. <code>--force --limit=100</code>.</dd>
                <dt class="col-sm-3">Prevent Overlap</dt>
                <dd class="col-sm-9">When enabled, the scheduler will skip this task if its previous execution is still running. Useful for long-running tasks.</dd>
                <dt class="col-sm-3">Priority</dt>
                <dd class="col-sm-9">Determines execution order when multiple tasks are due at the same time. <strong>Lower number = runs first</strong> (0 is highest priority).</dd>
                <dt class="col-sm-3">Timeout</dt>
                <dd class="col-sm-9">Maximum allowed execution time in seconds. If the task exceeds this, it will be terminated. Leave empty for the default (300s).</dd>
            </dl>
        </div>
    </div>
</div>

<form method="post" action="{{ path('caeligo_scheduler_task_edit_submit', { command: command }) }}">
    <input type="hidden" name="_token" value="{{ csrf_token('scheduler_edit_' ~ command) }}">

    <div class="card mb-4">
        <div class="card-header"><h5 class="mb-0">Schedule</h5></div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label fw-bold">Schedule Type</label>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="schedule_type" id="type_cron" value="cron"
                           {% if task_state.expression is not null or task_state.intervalSeconds is null %}checked{% endif %}>
                    <label class="form-check-label" for="type_cron">Cron Expression</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="schedule_type" id="type_interval" value="interval"
                           {% if task_state.intervalSeconds is not null and task_state.expression is null %}checked{% endif %}>
                    <label class="form-check-label" for="type_interval">Simple Interval</label>
                </div>
            </div>

            <div id="cron_fields" style="{% if task_state.intervalSeconds is not null and task_state.expression is null %}display:none{% endif %}">
                <div class="mb-3">
                    <label class="form-label fw-bold">Quick Presets</label>
                    <div class="d-flex flex-wrap gap-2 mb-2">
                        {% set presets = [
                            { label: '1 min',    cron: '* * * * *' },
                            { label: '5 min',    cron: '*/5 * * * *' },
                            { label: '10 min',   cron: '*/10 * * * *' },
                            { label: '15 min',   cron: '*/15 * * * *' },
                            { label: '30 min',   cron: '*/30 * * * *' },
                            { label: '1 hour',   cron: '0 * * * *' },
                            { label: '6 hours',  cron: '0 */6 * * *' },
                            { label: '12 hours', cron: '0 */12 * * *' },
                            { label: 'Daily',    cron: '0 0 * * *' },
                            { label: 'Weekly',   cron: '0 0 * * 1' },
                            { label: 'Monthly',  cron: '0 0 1 * *' },
                        ] %}
                        {% for preset in presets %}
                            <button type="button" class="btn btn-sm btn-outline-primary cron-preset-btn"
                                    data-cron="{{ preset.cron }}"
                                    title="{{ preset.cron }}">
                                {{ preset.label }}
                            </button>
                        {% endfor %}
                    </div>
                </div>
                <div class="mb-3">
                    <label for="expression" class="form-label">Cron Expression</label>
                    <input type="text" class="form-control font-monospace" id="expression" name="expression"
                           value="{{ task_state.expression }}" placeholder="0 * * * *">
                    <div id="cron-preview" class="form-text">
                        {% if task_state.expression %}
                            <strong>{{ task_state.expression|scheduler_describe }}</strong> — <code>{{ task_state.expression }}</code>
                        {% else %}
                            Format: minute hour day month weekday. Example: <code>0 * * * *</code> = every hour, <code>*/5 * * * *</code> = every 5 min
                        {% endif %}
                    </div>
                </div>
            </div>

            <div id="interval_fields" style="{% if task_state.expression is not null or task_state.intervalSeconds is null %}display:none{% endif %}">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label for="interval_value" class="form-label">Interval</label>
                        {% set iv = task_state.intervalSeconds ?? 0 %}
                        {% if iv >= 86400 %}
                            {% set display_value = (iv / 86400)|round %}
                            {% set display_unit = 'days' %}
                        {% elseif iv >= 3600 %}
                            {% set display_value = (iv / 3600)|round %}
                            {% set display_unit = 'hours' %}
                        {% else %}
                            {% set display_value = (iv / 60)|round %}
                            {% set display_unit = 'minutes' %}
                        {% endif %}
                        <input type="number" class="form-control" id="interval_value" name="interval_value"
                               value="{{ display_value }}" min="1">
                    </div>
                    <div class="col-md-6">
                        <label for="interval_unit" class="form-label">Unit</label>
                        <select class="form-select" id="interval_unit" name="interval_unit">
                            <option value="minutes" {% if display_unit|default('minutes') == 'minutes' %}selected{% endif %}>Minutes</option>
                            <option value="hours" {% if display_unit|default('') == 'hours' %}selected{% endif %}>Hours</option>
                            <option value="days" {% if display_unit|default('') == 'days' %}selected{% endif %}>Days</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header"><h5 class="mb-0">Options</h5></div>
        <div class="card-body">
            <div class="mb-3">
                <label for="arguments" class="form-label">Arguments</label>
                <input type="text" class="form-control font-monospace" id="arguments" name="arguments"
                       value="{{ task_state.arguments }}" placeholder="--option=value">
                <div class="form-text">Additional arguments passed to the command.</div>
            </div>

            <div class="mb-3 form-check">
                <input type="hidden" name="prevent_overlap" value="0">
                <input type="checkbox" class="form-check-input" id="prevent_overlap" name="prevent_overlap" value="1"
                       {% if task_state.preventOverlap %}checked{% endif %}>
                <label class="form-check-label" for="prevent_overlap">Prevent Overlap</label>
                <div class="form-text">Skip execution if the previous run is still in progress.</div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="priority" class="form-label">Priority</label>
                    <input type="number" class="form-control" id="priority" name="priority"
                           value="{{ task_state.priority }}" min="0">
                    <div class="form-text">Lower number = higher priority.</div>
                </div>
                <div class="col-md-6 mb-3">
                    <label for="timeout" class="form-label">Timeout (seconds)</label>
                    <input type="number" class="form-control" id="timeout" name="timeout"
                           value="{{ task_state.timeout }}" min="0" placeholder="Default (300s)">
                    <div class="form-text">Leave empty to use the global default.</div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save Configuration</button>
        <a href="{{ path('caeligo_scheduler_index') }}" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

<script>
document.addEventListener('DOMContentLoaded', function() {
    var cronFields = document.getElementById('cron_fields');
    var intervalFields = document.getElementById('interval_fields');
    var typeCron = document.getElementById('type_cron');
    var typeInterval = document.getElementById('type_interval');

    function toggleScheduleType() {
        var isCron = typeCron.checked;
        cronFields.style.display = isCron ? 'block' : 'none';
        intervalFields.style.display = isCron ? 'none' : 'block';
        cronFields.querySelectorAll('input, select').forEach(function(el) { el.disabled = !isCron; });
        intervalFields.querySelectorAll('input, select').forEach(function(el) { el.disabled = isCron; });
    }

    typeCron.addEventListener('change', toggleScheduleType);
    typeInterval.addEventListener('change', toggleScheduleType);
    toggleScheduleType();

    var cronInput = document.getElementById('expression');
    var presetBtns = document.querySelectorAll('.cron-preset-btn');

    function describeCron(expr) {
        expr = expr.trim();
        if (!expr) return '';
        var p = expr.split(/\s+/);
        if (p.length !== 5) return 'Invalid expression (need 5 fields)';
        var minute = p[0], hour = p[1], day = p[2], month = p[3], weekday = p[4];
        var dayNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
        var monthNames = ['','Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        var pad = function(v) { return ('0'+v).slice(-2); };
        function ordinal(n) { var s=['th','st','nd','rd']; var v=n%100; return n+(s[(v-20)%10]||s[v]||s[0]); }

        // Every minute
        if (minute==='*' && hour==='*' && day==='*' && month==='*' && weekday==='*') return 'Every minute';
        // Every N minutes
        if (minute.indexOf('*/')===0 && hour==='*' && day==='*' && month==='*' && weekday==='*') {
            var n=parseInt(minute.slice(2)); return 'Every '+n+' minute'+(n!==1?'s':'');
        }
        // Every hour at :MM
        if (/^\d+$/.test(minute) && hour==='*' && day==='*' && month==='*' && weekday==='*') {
            return minute==='0' ? 'Every hour' : 'Every hour at :'+pad(minute);
        }
        // Every N hours
        if (/^\d+$/.test(minute) && hour.indexOf('*/')===0 && day==='*' && month==='*' && weekday==='*') {
            var n=parseInt(hour.slice(2)); return 'Every '+n+' hour'+(n!==1?'s':'')+' at :'+pad(minute);
        }
        var time = pad(hour)+':'+pad(minute);
        // Weekly on weekday(s)
        if (weekday!=='*' && day==='*' && month==='*' && /^\d+$/.test(hour) && /^\d+$/.test(minute)) {
            if (weekday.indexOf(',')>-1) {
                var names=weekday.split(',').map(function(d){return dayNames[parseInt(d.trim())]||d.trim();});
                return 'Weekly on '+names.join(', ')+' at '+time;
            }
            return 'Weekly on '+(dayNames[parseInt(weekday)]||weekday)+' at '+time;
        }
        // Monthly on day
        if (/^\d+$/.test(day) && month==='*' && weekday==='*' && /^\d+$/.test(hour) && /^\d+$/.test(minute)) {
            return 'Monthly on the '+ordinal(parseInt(day))+' at '+time;
        }
        // Daily at time
        if (/^\d+$/.test(hour) && /^\d+$/.test(minute) && day==='*' && month==='*' && weekday==='*') {
            return 'Daily at '+time;
        }
        // Yearly
        if (/^\d+$/.test(month) && /^\d+$/.test(day) && /^\d+$/.test(hour) && /^\d+$/.test(minute) && weekday==='*') {
            return 'Yearly on '+(monthNames[parseInt(month)]||month)+' '+parseInt(day)+' at '+time;
        }
        return 'Custom expression';
    }

    function updatePresetHighlight() {
        var val = cronInput.value.trim();
        presetBtns.forEach(function(btn) {
            if (btn.getAttribute('data-cron') === val) {
                btn.classList.remove('btn-outline-primary');
                btn.classList.add('btn-primary');
            } else {
                btn.classList.remove('btn-primary');
                btn.classList.add('btn-outline-primary');
            }
        });
        var preview = document.getElementById('cron-preview');
        var desc = describeCron(val);
        if (val && desc) {
            preview.innerHTML = '<strong>' + desc + '</strong> — <code>' + val + '</code>';
        } else if (val) {
            preview.innerHTML = 'Custom expression: <code>' + val + '</code>';
        } else {
            preview.textContent = 'Format: minute hour day month weekday';
        }
    }

    presetBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
            cronInput.value = this.getAttribute('data-cron');
            typeCron.checked = true;
            toggleScheduleType();
            updatePresetHighlight();
            cronInput.focus();
        });
    });

    cronInput.addEventListener('input', updatePresetHighlight);
    updatePresetHighlight();
});
</script>
{% endblock %}
