{% extends base_template|default('@CaeligoScheduler/base.html.twig') %}

{% block title %}Settings{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Settings</h2>
    <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#settings-help" aria-expanded="false">
        <i class="fa fa-circle-question"></i> Help
    </button>
</div>

<div class="collapse mb-4" id="settings-help">
    <div class="card">
        <div class="card-body">
            <h6 class="card-title"><i class="fa fa-circle-info"></i> Scheduler Settings</h6>
            <dl class="row mb-0">
                <dt class="col-sm-3">Crontab</dt>
                <dd class="col-sm-9">The scheduler needs a system crontab entry to run periodically (usually every minute). The crontab calls <code>scheduler:run</code>, which checks all enabled tasks and executes those that are due.</dd>
                <dt class="col-sm-3">Install / Uninstall</dt>
                <dd class="col-sm-9">Use the <strong>Install Crontab</strong> button to automatically add the crontab entry to the current user's crontab. <strong>Uninstall</strong> removes it. Requires ROLE_SUPERADMIN.</dd>
                <dt class="col-sm-3">Expected entry</dt>
                <dd class="col-sm-9">The crontab line the scheduler expects to find. If you prefer to manage crontab manually, copy this line into <code>crontab -e</code>.</dd>
                <dt class="col-sm-3">Storage</dt>
                <dd class="col-sm-9">Task state (schedules, enabled status) and execution logs are stored as JSON files on disk. The path shown is where these files are located.</dd>
            </dl>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Crontab</h5>
    </div>
    <div class="card-body">
        <div class="mb-3">
            <strong>Status:</strong>
            {% if crontab_status == 'INSTALLED' %}
                <span class="badge bg-success">Installed</span>
            {% elseif crontab_status == 'NOT_INSTALLED' %}
                <span class="badge bg-danger">Not Installed</span>
            {% else %}
                <span class="badge bg-secondary">Unsupported</span>
            {% endif %}
        </div>

        {% if crontab_entry %}
            <div class="mb-3">
                <strong>Current entry:</strong>
                <code class="d-block mt-1 p-2 rounded scheduler-code-block">{{ crontab_entry }}</code>
            </div>
        {% endif %}

        <div class="mb-3">
            <strong>Expected entry:</strong>
                <code class="d-block mt-1 p-2 rounded scheduler-code-block">{{ crontab_preview }}</code>
        </div>

        {% if can_manage_crontab %}
            <div class="d-flex gap-2">
                {% if crontab_status == 'NOT_INSTALLED' %}
                    <form method="post" action="{{ path('caeligo_scheduler_crontab_install') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('scheduler_crontab_install') }}">
                        <button type="submit" class="btn btn-success btn-sm">Install Crontab</button>
                    </form>
                {% elseif crontab_status == 'INSTALLED' %}
                    <form method="post" action="{{ path('caeligo_scheduler_crontab_uninstall') }}"
                          onsubmit="return confirm('Are you sure you want to remove the scheduler crontab entry?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('scheduler_crontab_uninstall') }}">
                        <button type="submit" class="btn btn-danger btn-sm">Uninstall Crontab</button>
                    </form>
                {% endif %}
            </div>
        {% else %}
            <div class="alert alert-warning mt-2 mb-0">
                You need elevated permissions to manage crontab entries.
            </div>
        {% endif %}
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Storage</h5>
    </div>
    <div class="card-body">
        <div class="mb-2">
            <strong>State directory:</strong> <code>{{ state_dir }}</code>
        </div>
        <div class="text-muted">
            Task state and execution logs are stored as JSON files in this directory.
        </div>
    </div>
</div>
{% endblock %}
