{% extends base_template|default('@CaeligoScheduler/base.html.twig') %}

{% block title %}{% if command %}Logs — {{ command }}{% else %}All Logs{% endif %}{% endblock %}

{% block scheduler_content %}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('caeligo_scheduler_index') }}">Tasks</a></li>
        {% if command %}
            <li class="breadcrumb-item active">Logs: {{ command }}</li>
        {% else %}
            <li class="breadcrumb-item active">All Logs</li>
        {% endif %}
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">
        {% if command %}
            Execution Logs: <code>{{ command }}</code>
            {% if command_info %}
                <small class="text-muted d-block fs-6">{{ command_info.description }}</small>
            {% endif %}
        {% else %}
            All Execution Logs
        {% endif %}
    </h2>
    <div class="d-flex gap-2">
        {% if logs is not empty %}
            {% if command %}
                <form method="post" action="{{ path('caeligo_scheduler_task_logs_clear', { command: command }) }}" onsubmit="return confirm('Clear all logs for {{ command }}?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('scheduler_clear_logs_' ~ command) }}">
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                        <i class="fa fa-trash"></i> Clear Logs
                    </button>
                </form>
            {% else %}
                <form method="post" action="{{ path('caeligo_scheduler_logs_clear') }}" onsubmit="return confirm('Clear ALL scheduler logs?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('scheduler_clear_all_logs') }}">
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                        <i class="fa fa-trash"></i> Clear All Logs
                    </button>
                </form>
            {% endif %}
        {% endif %}
        <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#logs-help" aria-expanded="false">
            <i class="fa fa-circle-question"></i> Help
        </button>
    </div>
</div>

<div class="collapse mb-4" id="logs-help">
    <div class="card">
        <div class="card-body">
            <h6 class="card-title"><i class="fa fa-circle-info"></i> Reading execution logs</h6>
            <dl class="row mb-0">
                <dt class="col-sm-3">Started At</dt>
                <dd class="col-sm-9">When the task execution began.</dd>
                <dt class="col-sm-3">Duration</dt>
                <dd class="col-sm-9">How long the execution took (shown in ms, seconds, or minutes).</dd>
                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    <span class="badge bg-success">Success</span> — Completed with exit code 0.<br>
                    <span class="badge bg-danger">Failed</span> — Exited with a non-zero exit code.<br>
                    <span class="badge bg-warning">Running</span> — Currently in progress.<br>
                    <span class="badge bg-secondary">Skipped</span> — Was skipped (e.g. overlap prevention).
                </dd>
                <dt class="col-sm-3">Exit Code</dt>
                <dd class="col-sm-9">
                    The process exit code. <code>0</code> = success, any other value indicates an error.
                    <details class="mt-1">
                        <summary class="text-muted" style="cursor:pointer">Common exit codes</summary>
                        <table class="table table-sm mt-1 mb-0" style="font-size: 0.85em;">
                            <tbody>
                                <tr><td><code>0</code></td><td>Success</td></tr>
                                <tr><td><code>1</code></td><td>General error</td></tr>
                                <tr><td><code>2</code></td><td>Invalid arguments / misuse of command</td></tr>
                                <tr><td><code>3</code></td><td>Command could not be executed</td></tr>
                                <tr><td><code>7</code></td><td>Runtime error (missing service, failed dependency)</td></tr>
                                <tr><td><code>126</code></td><td>Permission denied (not executable)</td></tr>
                                <tr><td><code>127</code></td><td>Command not found</td></tr>
                                <tr><td><code>130</code></td><td>Interrupted (SIGINT / Ctrl+C)</td></tr>
                                <tr><td><code>137</code></td><td>Killed (SIGKILL) — likely out of memory</td></tr>
                                <tr><td><code>139</code></td><td>Segmentation fault (SIGSEGV)</td></tr>
                                <tr><td><code>143</code></td><td>Terminated (SIGTERM)</td></tr>
                                <tr><td><code>255</code></td><td>Exit status out of range</td></tr>
                            </tbody>
                        </table>
                    </details>
                </dd>
                <dt class="col-sm-3">Output</dt>
                <dd class="col-sm-9">Click <strong>Show</strong> to expand the stdout and stderr output captured during execution.</dd>
            </dl>
        </div>
    </div>
</div>

{% if logs is empty %}
    <div class="alert alert-info">No execution logs found.</div>
{% else %}
    {% include '@CaeligoScheduler/_partials/_log_table.html.twig' with { logs: logs, show_command: command is null } %}
{% endif %}

{% if command %}
    <a href="{{ path('caeligo_scheduler_index') }}" class="btn btn-outline-secondary">Back to Tasks</a>
{% endif %}
{% endblock %}
