<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Scheduler{% endblock %} — Caeligo Scheduler</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YcnS/1p8MThwOezS3+PDE6Gv/EDzBuoSTQ9a" crossorigin="anonymous">
    <style>
        body { font-size: 0.9rem; }
        .sidebar { min-height: 100vh; background: #212529; }
        .sidebar a { color: rgba(255,255,255,.75); text-decoration: none; display: block; padding: 0.6rem 1rem; }
        .sidebar a:hover, .sidebar a.active { color: #fff; background: rgba(255,255,255,.1); }
        .sidebar .brand { color: #fff; font-weight: 600; font-size: 1.1rem; padding: 1rem; border-bottom: 1px solid rgba(255,255,255,.1); }
        .content { padding: 1.5rem; }
        .badge { font-size: 0.8em; }
        .table td, .table th { vertical-align: middle; }
        .output-preview { max-height: 200px; overflow-y: auto; font-family: monospace; font-size: 0.8rem; white-space: pre-wrap; background: #f8f9fa; padding: 0.5rem; border-radius: 4px; }
        .scheduler-code-block { background: #f8f9fa; }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-2 d-none d-md-block sidebar">
                <div class="brand">⏰ Caeligo Scheduler</div>
                <div class="pt-3">
                    <a href="{{ path('caeligo_scheduler_index') }}" class="{% if app.request.attributes.get('_route') == 'caeligo_scheduler_index' %}active{% endif %}">
                        📋 Tasks
                    </a>
                    <a href="{{ path('caeligo_scheduler_logs') }}" class="{% if app.request.attributes.get('_route') in ['caeligo_scheduler_logs', 'caeligo_scheduler_task_logs'] %}active{% endif %}">
                        📄 Logs
                    </a>
                    <a href="{{ path('caeligo_scheduler_settings') }}" class="{% if app.request.attributes.get('_route') == 'caeligo_scheduler_settings' %}active{% endif %}">
                        ⚙️ Settings
                    </a>
                </div>
            </nav>

            <main class="col-md-10 ms-sm-auto content">
                {% include '@CaeligoScheduler/_partials/_flash_messages.html.twig' %}
                {% block body %}{% endblock %}
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>
