{
    "name": "caeligo/scheduler-bundle",
    "description": "File-based task scheduler bundle for Symfony with CLI and web dashboard",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "symfony",
        "scheduler",
        "cron",
        "task",
        "bundle",
        "dashboard"
    ],
    "authors": [
        {
            "name": "Caeligo",
            "email": "info@caeligo.dev"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/framework-bundle": "^6.4 || ^7.0",
        "symfony/console": "^6.4 || ^7.0",
        "symfony/process": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/config": "^6.4 || ^7.0",
        "symfony/filesystem": "^6.4 || ^7.0",
        "symfony/twig-bundle": "^6.4 || ^7.0",
        "symfony/routing": "^6.4 || ^7.0",
        "symfony/security-bundle": "^6.4 || ^7.0",
        "dragonmantank/cron-expression": "^3.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0",
        "symfony/phpunit-bridge": "^6.4 || ^7.0"
    },
    "suggest": {
        "easycorp/easyadmin-bundle": "For EasyAdmin dashboard integration (^4.0)",
        "symfony/lock": "For distributed mutex in multi-server environments (^6.4 || ^7.0)"
    },
    "autoload": {
        "psr-4": {
            "Caeligo\\SchedulerBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Caeligo\\SchedulerBundle\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    }
}
